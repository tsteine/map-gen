{
  "experiment_name": "norfair-testing",
  "room_set": "room_definitions/norfair.json",
  "map_size": [72, 72],
  "knot_episodes": [0, 100000, 500000, 4000000, 16000000],
  "checkpoint_period": 100,
  "visualize": 1,
  "distance_proximity_scale": 5.0,
  "model": {
    "compile": true,
    "autocast": true,
    "generation_autocast": true,
    "embedding_width": 256,
    "global_embedding_width": 256,
    "hidden_width": 256,
    "proposal_hidden_widths": [512],
    "missing_connect_query_hidden_width": 256,
    "missing_connect_query_frontier_width": 32,
    "missing_connect_query_distance_width": 4,
    "utility_query_hidden_width": 32,
    "utility_query_frontier_width": 32,
    "known_save_refill_utility_override": false,
    "num_layers": 4
  },
  "optimizer": {
    "type": "muon",
    "muon": {
      "lr": {"log": [0.0005, 0.0005, 0.0002, 0.00005, 0.00002]},
      "momentum": 0.95,
      "nesterov": true,
      "backend": "newtonschulz5",
      "backend_steps": 5
    },
    "adam": {
      "lr": {"log": [0.001, 0.001, 0.0005, 0.0001, 0.00005]},
      "beta1": 0.95,
      "beta2": 0.99
    }
  },
  "balance_model": {
    "hidden_width": 64,
    "num_layers": 1
  },
  "balance_optimizer": {
    "type": "adam",
    "lr": {"log": [0.001, 0.001, 0.0005, 0.0001, 0.00005]},
    "beta1": 0.95,
    "beta2": 0.99
  },
  "generation": {
    "num_environments": 8192,
    "num_iterations": 1,
    "num_devices": 2,
    "pipeline_groups": 4,
    "gpu_prefetch_batches": 1,
    "recommended_candidates": 4,
    "shortlist_candidates": 128,
    "num_scored_invalid_candidates": 4,
    "max_candidate_areas_per_placement": 2,
    "temperature": {"log": [10.0, 2.0, 0.03, 0.03, 0.03]},
    "proposal_temperature": 1.0,
    "reward_door": 1.0,
    "reward_connection": 1.0,
    "reward_toilet": 1.0,
    "reward_phantoon": 1.0,
    "reward_balance": {"log": [0.01, 0.2, 0.2, 0.1, 0.05]},
    "reward_toilet_balance": {"log": [0.01, 0.2, 0.2, 0.05, 0.05]},
    "reward_frontier": 0.0,
    "reward_graph_diameter": 0.1,
    "reward_save_distance": 0.1,
    "reward_refill_distance": 0.1,
    "reward_missing_connect_utility": 0.5,
    "reward_area_crossing": 0.0,
    "reward_area_size_valid": 1.0,
    "reward_area_map_station": 1.0,
    "min_area_size": 20,
    "max_area_size": 300,
    "frontier_neighbor_algorithm": "nearest-exclusive",
    "frontier_neighbor_count": 4,
    "frontier_window_size": 8,
    "candidate_spatial_cell_size": 8,
    "area_bounding_box_width": 61,
    "area_bounding_box_height": 30,
    "num_threads": 32
  },
  "features": {
    "inventory": true,
    "temperature": true,
    "recommended_candidates": false,
    "generation_variable_floats": true,
    "lookahead_outcomes": 128,
    "room_position": true,
    "global_room_position": 256,
    "room_part_furthest_distance": 1,
    "room_part_save_distance": 1,
    "room_part_refill_distance": 1,
    "room_part_frontier_distance": 1,
    "frontier_mask": true,
    "frontier_position": 128,
    "frontier_orientation": 4,
    "frontier_kind": 5,
    "frontier_door_variant": 64,
    "frontier_occupancy": true,
    "frontier_neighbor": true,
    "frontier_neighbor_position_embedding": 256,
    "frontier_neighbor_flags": true,
    "connection_reachability": 0,
    "frontier_connection_reachability": false,
    "area_state": true,
    "frontier_area": 6,
    "missing_connect_query": true,
    "save_utility_query": true,
    "refill_utility_query": true,
    "toilet_crossed_room": 32,
    "known_distance": 1
  },
  "train": {
    "batch_size": 1024,
    "fresh_pass_factor": 2.0,
    "replay_pass_factor": 2.0,
    "sample_period": 16,
    "episodes_per_file": 64,
    "ema_decay": {"linear": [0.95, 0.99, 0.99, 0.99, 0.99]},
    "hist_c": 3.0,
    "door_weight": 1.0,
    "connection_weight": 1.0,
    "toilet_weight": 2.0,
    "phantoon_weight": 2.0,
    "balance_weight": 1.0,
    "toilet_balance_weight": 2.0,
    "avg_frontiers_weight": 0.0,
    "graph_diameter_weight": 0.05,
    "save_distance_weight": 0.5,
    "refill_distance_weight": 0.5,
    "missing_connect_utility_weight": 1.0,
    "area_crossing_weight": 0.0,
    "area_size_weight": 0.1,
    "area_map_station_weight": 0.1,
    "proposal_weight": 0.005,
    "pipeline_groups": 4,
    "gradient_accumulation_steps": 2,
    "shuffle_buffer_batches": 1
  }
}
