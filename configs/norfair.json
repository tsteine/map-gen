{
  "experiment_name": "norfair-testing",
  "room_set": "room_definitions/norfair.json",
  "map_size": [72, 72],
  "knot_episodes": [0, 200000, 1000000, 4000000, 16000000],
  "checkpoint_period": 100,
  "model": {
    "compile": true,
    "autocast": true,
    "generation_autocast": true,
    "embedding_width": 512,
    "global_embedding_width": 512,
    "hidden_width": 512,
    "door_match_embedding_width": 64,
    "num_layers": 4
  },
  "optimizer": {
    "lr": {"log": [0.0005, 0.0004, 0.0003, 0.0002, 0.0001]},
    "beta1": 0.95,
    "beta2": 0.99
  },
  "balance_model": {
    "hidden_width": 64,
    "num_layers": 1
  },
  "balance_optimizer": {
    "lr": {"log": [0.001, 0.0003, 0.0001, 0.00005, 0.00002]},
    "beta1": 0.95,
    "beta2": 0.99
  },
  "generation": {
    "num_environments": 2048,
    "num_iterations": 4,
    "num_devices": 2,
    "pipeline_groups": 2,
    "recommended_candidates": {"log": [1, 4, 8, 16, 16]},
    "exploration_candidates": 0,
    "temperature": {"log": [10.0, 1.0, 0.03, 0.03, 0.03]},
    "proposal_temperature": {"log": [10.0, 1.0, 0.03, 0.03, 0.03]},
    "reward_door": 1.0,
    "reward_connection": 1.0,
    "reward_balance": 0.2,
    "frontier_neighbor_algorithm": "nearest-exclusive",
    "frontier_neighbor_count": 1,
    "frontier_window_size": 16,
    "num_threads": 32
  },
  "features": {
    "inventory": true,
    "temperature": true,
    "recommended_candidates": true,
    "exploration_candidates": true,
    "lookahead_outcomes": true,
    "room_position": true,
    "frontier_mask": true,
    "frontier_position": true,
    "frontier_orientation": true,
    "frontier_kind": true,
    "frontier_occupancy": true,
    "frontier_neighbor": true,
    "frontier_neighbor_position_embedding": false,
    "frontier_neighbor_flags": true,
    "connection_reachability": true,
    "frontier_connection_reachability": true
  },
  "train": {
    "batch_size": 512,
    "fresh_pass_factor": 2.0,
    "replay_pass_factor": 2.0,
    "sample_period": 16,
    "episodes_per_file": 64,
    "ema_decay": 0.995,
    "hist_c": 3.0,
    "door_weight": 1.0,
    "connection_weight": 1.0,
    "balance_weight": 1.0,
    "proposal_weight": 0.02,
    "pipeline_groups": 4,
    "gradient_accumulation_steps": 1
  }
}
