{
  "experiment_name": "norfair-initial-testing",
  "room_set": "room_definitions/norfair.json",
  "annealing_episodes": 500000,
  "total_episodes": 4000000,
  "map_size": [72, 72],
  "model": {
    "type": "frontier_state",
    "compile": true,
    "autocast": true,
    "generation_autocast": true,
    "embedding_width": 256,
    "key_width": 64,
    "value_width": 64,
    "attn_heads": 16,
    "head_groups": 4,
    "hidden_width": 256,
    "num_layers": 2
  },
  "optimizer": {
    "lr": 0.0003,
    "beta1": 0.95,
    "beta2": 0.99
  },
  "generation": {
    "num_environments": 1024,
    "num_iterations": 8,
    "num_devices": 2,
    "state_pipeline_cohorts": 2,
    "action_candidates": 16,
    "lookahead_outcomes": false,
    "temperature0": 10.0,
    "temperature1": 0.03,
    "state_candidate_chunk": 16,
    "state_environment_chunk": 256,
    "frontier_neighbor_algorithm": "nearest-exclusive",
    "frontier_neighbor_count": 4,
    "frontier_window_size": 16,
    "num_threads": 32
  },
  "state_features": {
    "inventory": true,
    "room_position": true,
    "frontier_mask": true,
    "frontier_position": true,
    "frontier_orientation": true,
    "frontier_kind": true,
    "frontier_occupancy": true,
    "frontier_neighbor": true,
    "frontier_neighbor_position": true,
    "frontier_neighbor_flags": true,
    "connection_reachability": true,
    "frontier_connection_reachability": true
  },
  "train": {
    "batch_size": 512,
    "fresh_pass_factor": 2.0,
    "replay_pass_factor": 2.0,
    "episodes_per_file": 64,
    "ema_decay": 0.995,
    "hist_c": 3.0,
    "door_weight": 1.0,
    "connection_weight": 1.0,
    "state_prefix_samples": 4,
    "state_batch_chunk": 512,
    "state_gpu_chunk": 512,
    "state_pipeline_cohorts": 4,
    "gradient_accumulation_steps": 1
  }
}
