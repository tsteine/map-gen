{
  "experiment_name": "crateria-initial-testing",
  "room_set": "room_definitions/crateria.json",
  "annealing_episodes": 1000000,
  "total_episodes": 4000000,
  "map_size": [72, 72],
  "model": {
    "type": "frontier_state",
    "embedding_width": 128,
    "key_width": 32,
    "value_width": 32,
    "attn_heads": 8,
    "head_groups": 4,
    "hidden_width": 256,
    "num_layers": 2
  },
  "optimizer": {
    "lr": 0.0005,
    "beta1": 0.95,
    "beta2": 0.95
  },
  "generation": {
    "num_environments": 8192,
    "action_candidates": 8,
    "lookahead_outcomes": true,
    "temperature0": 10.0,
    "temperature1": 0.03,
    "state_candidate_chunk": 16,
    "state_environment_chunk": 512
  },
  "train": {
    "batch_size": 64,
    "fresh_pass_factor": 1.0,
    "replay_pass_factor": 1.0,
    "episodes_per_file": 64,
    "ema_decay": 0.995,
    "hist_c": 3.0,
    "door_weight": 1.0,
    "connection_weight": 1.0,
    "state_prefix_samples": 8,
    "state_batch_chunk": 512
  }
}
