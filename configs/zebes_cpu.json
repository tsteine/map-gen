{
  "experiment_name": "zebes-testing",
  "room_set": "room_definitions/zebes.json",
  "map_size": [72, 72],
  "knot_episodes": [0, 100000, 500000, 4000000, 16000000],
  "checkpoint_period": 100,
  "visualize": 1,
  "distance_proximity_scale": 1.0,
  "model": {
    "compile": true,
    "autocast": true,
    "generation_autocast": true,
    "embedding_width": 512,
    "global_embedding_width": 512,
    "hidden_width": 512,
    "proposal_hidden_width": 64,
    "missing_connect_query_hidden_width": 512,
    "missing_connect_query_frontier_width": 64,
    "missing_connect_query_distance_width": 16,
    "utility_query_hidden_width": 512,
    "utility_query_frontier_width": 64,
    "utility_query_kind_width": 16,
    "known_save_refill_utility_override": false,
    "num_layers": 4
  },
  "optimizer": {
    "type": "muon",
    "muon": {
      "lr": {"log": [0.0005, 0.0002, 0.0001, 0.00005, 0.00002]},
      "momentum": 0.95,
      "nesterov": true,
      "backend": "newtonschulz5",
      "backend_steps": 5
    },
    "adam": {
      "lr": {"log": [0.001, 0.0005, 0.0003, 0.0002, 0.0001]},
      "beta1": 0.95,
      "beta2": 0.99
    }
  },
  "balance_model": {
    "hidden_width": 64,
    "num_layers": 1
  },
  "balance_optimizer": {
    "type": "adam",
    "lr": {"log": [0.001, 0.0003, 0.0001, 0.00005, 0.00002]},
    "beta1": 0.95,
    "beta2": 0.99
  },
  "generation": {
    "num_environments": 1,
    "num_iterations": 1,
    "num_devices": 1,
    "pipeline_groups": 1,
    "recommended_candidates": 4,
    "shortlist_candidates": 16,
    "temperature": {"log": [10.0, 1.0, 0.03, 0.03, 0.03]},
    "proposal_temperature": 0.1,
    "reward_door": 1.0,
    "reward_connection": 1.0,
    "reward_toilet": 1.0,
    "reward_balance": 0.2,
    "reward_toilet_balance": 0.2,
    "reward_frontier": 0.0,
    "reward_graph_diameter": 0.0,
    "reward_save_distance": 0.0,
    "reward_refill_distance": 0.0,
    "reward_missing_connect_utility": 0.0,
    "frontier_neighbor_algorithm": "nearest-exclusive",
    "frontier_neighbor_count": 1,
    "frontier_window_size": 8,
    "candidate_spatial_cell_size": 8,
    "num_threads": 32
  },
  "features": {
    "inventory": true,
    "temperature": true,
    "recommended_candidates": true,
    "lookahead_outcomes": 128,
    "room_position": true,
    "global_room_position": 512,
    "room_part_furthest_distance": 1,
    "room_part_save_distance": 1,
    "room_part_refill_distance": 1,
    "room_part_frontier_distance": 1,
    "frontier_mask": true,
    "frontier_position": 512,
    "frontier_orientation": 512,
    "frontier_kind": 512,
    "frontier_door_variant": 512,
    "frontier_occupancy": true,
    "frontier_neighbor": true,
    "frontier_neighbor_position_embedding": 512,
    "frontier_neighbor_flags": true,
    "connection_reachability": 512,
    "frontier_connection_reachability": true,
    "missing_connect_query": true,
    "save_utility_query": false,
    "refill_utility_query": false,
    "toilet_crossed_room": 32,
    "known_distance": 1
  },
  "train": {
    "batch_size": 512,
    "fresh_pass_factor": 0.0,
    "replay_pass_factor": 0.0,
    "sample_period": 16,
    "episodes_per_file": 64,
    "ema_decay": {"linear": [0.95, 0.99, 0.99, 0.99, 0.99]},
    "hist_c": 3.0,
    "door_weight": 1.0,
    "connection_weight": 1.0,
    "toilet_weight": 1.0,
    "balance_weight": 1.0,
    "toilet_balance_weight": 1.0,
    "avg_frontiers_weight": 0.1,
    "graph_diameter_weight": 0.0,
    "save_distance_weight": 0.0,
    "refill_distance_weight": 0.0,
    "missing_connect_utility_weight": 0.0,
    "proposal_weight": 0.005,
    "pipeline_groups": 4,
    "gradient_accumulation_steps": 1,
    "shuffle_buffer_batches": 1
  }
}
