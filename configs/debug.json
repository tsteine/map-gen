{
  "experiment_name": "crateria-testing",
  "room_set": "room_definitions/crateria.json",
  "map_size": [72, 72],
  "knot_episodes": [0, 640],
  "checkpoint_period": 100,
  "visualize": 1,
  "distance_proximity_scale": 1.0,
  "model": {
    "compile": false,
    "autocast": true,
    "generation_autocast": true,
    "embedding_width": 256,
    "global_embedding_width": 256,
    "hidden_width": 256,
    "proposal_hidden_width": 64,
    "missing_connect_query_hidden_width": 256,
    "missing_connect_query_frontier_width": 64,
    "missing_connect_query_distance_width": 16,
    "utility_query_hidden_width": 256,
