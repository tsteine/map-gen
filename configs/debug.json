    "known_save_refill_utility_override": false,
    "num_layers": 2
  },
  "optimizer": {
    "type": "adam",
    "lr": 0.001,
    "beta1": 0.95,
    "beta2": 0.99
  },
  "balance_model": {
    "hidden_width": 64,
    "num_layers": 1
  },
  "balance_optimizer": {
    "type": "adam",
    "lr": 0.001,
    "beta1": 0.95,
    "beta2": 0.99
  },
  "generation": {
    "num_environments": 256,
    "num_iterations": 1,
    "num_devices": 1,
    "pipeline_groups": 1,
    "gpu_prefetch_batches": 1,
    "recommended_candidates": 4,
    "shortlist_candidates": 16,
    "temperature": 1.0,
    "proposal_temperature": 1.0,
    "reward_door": 1.0,
    "reward_connection": 1.0,
    "reward_toilet": 1.0,
    "reward_phantoon": 1.0,
    "reward_balance": 0.2,
    "reward_toilet_balance": 0.2,
    "reward_frontier": 0.0,
    "reward_graph_diameter": 0.0,
    "reward_save_distance": 0.0,
    "reward_refill_distance": 0.0,
    "reward_missing_connect_utility": 0.0,
    "frontier_neighbor_algorithm": "nearest-exclusive",
    "frontier_neighbor_count": 1,
    "frontier_window_size": 16,
    "candidate_spatial_cell_size": 8,
    "num_threads": 32
  },
  "features": {
    "inventory": true,
    "temperature": true,
    "recommended_candidates": true,
    "generation_variable_floats": true,
    "lookahead_outcomes": 64,
    "room_position": true,
    "global_room_position": 256,
    "room_part_furthest_distance": 1,
    "room_part_save_distance": 1,
    "room_part_refill_distance": 1,
    "room_part_frontier_distance": 1,
    "frontier_mask": true,
    "frontier_position": 256,
    "frontier_orientation": 256,
    "frontier_kind": 256,
    "frontier_door_variant": 256,
    "frontier_occupancy": true,
    "frontier_neighbor": true,
    "frontier_neighbor_position_embedding": 0,
    "frontier_neighbor_flags": true,
    "connection_reachability": 256,
    "frontier_connection_reachability": true,
    "missing_connect_query": true,
    "save_utility_query": false,
    "refill_utility_query": false,
    "toilet_crossed_room": 32,
    "known_distance": 1
