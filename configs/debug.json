  "train": {
    "batch_size": 256,
    "fresh_pass_factor": 2.0,
    "replay_pass_factor": 2.0,
    "sample_period": 16,
    "episodes_per_file": 64,
    "ema_decay": 0.995,
    "hist_c": 3.0,
    "door_weight": 1.0,
    "connection_weight": 1.0,
    "toilet_weight": 1.0,
    "phantoon_weight": 1.0,
    "balance_weight": 5.0,
    "toilet_balance_weight": 5.0,
    "avg_frontiers_weight": 0.01,
    "graph_diameter_weight": 0.0,
    "save_distance_weight": 0.0,
    "refill_distance_weight": 0.0,
    "missing_connect_utility_weight": 0.0,
    "proposal_weight": 0.1,
    "pipeline_groups": 4,
    "gradient_accumulation_steps": 1,
    "shuffle_buffer_batches": 16
